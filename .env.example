APP_NAME=Fashion Multimodal Search
APP_VERSION=0.1.0

# 所有路径都支持相对项目根目录配置，避免写死本机绝对路径。
DATA_DIR=data
MODEL_DIR=models
OUTPUT_DIR=outputs
UPLOADS_TMP_DIR=uploads/tmp

# 搜索默认参数，后续真实搜索服务会复用。
TOP_K=20
USE_RERANK=true

# 第一阶段只做上传请求形态校验，仍然保留大小和类型配置。
MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# 前端开发服务器地址。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
